<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GenValNumAl.ViewModels"
             x:Class="GenValNumAl.Views.MidSquareView"
             x:DataType="vm:MitadCuadradoViewModel">

  <Grid RowDefinitions="Auto,*,Auto,Auto">

    <!-- ── Encabezado + formulario ─────────────────────────────────────── -->
    <ScrollViewer Grid.Row="0"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  MaxHeight="340">
      <StackPanel Margin="32,28,32,16" Spacing="0">

        <TextBlock Classes="section-title" Text="Mitad del Cuadrado" />
        <TextBlock Classes="formula"
                   Text="Xₙ₊₁ = dígitos centrales de Xₙ²    Uₙ = Xₙ / 10^d" />

        <!-- Campos -->
        <Grid ColumnDefinitions="*,16,*,16,*">

          <StackPanel Grid.Column="0">
            <TextBlock Classes="input-label" Text="Semilla X₀" />
            <TextBox Classes="input-field"
                     Text="{Binding X0}"
                     Watermark="ej: 1234" />
          </StackPanel>

          <StackPanel Grid.Column="2">
            <TextBlock Classes="input-label" Text="Dígitos (d, par)" />
            <TextBox Classes="input-field"
                     Text="{Binding Digitos}"
                     Watermark="ej: 4" />
          </StackPanel>

          <StackPanel Grid.Column="4">
            <TextBlock Classes="input-label" Text="Cantidad (n)" />
            <TextBox Classes="input-field"
                     Text="{Binding N}"
                     Watermark="ej: 20" />
          </StackPanel>

        </Grid>

        <!-- Error -->
        <Border Classes="error-panel" IsVisible="{Binding TieneError}">
          <Grid ColumnDefinitions="22,8,*">
            <TextBlock Grid.Column="0" Text="⚠" Foreground="#FF6B6B" FontSize="16" VerticalAlignment="Top" />
            <TextBlock Grid.Column="2"
                       Text="{Binding MensajeError}"
                       Foreground="#FF9999"
                       TextWrapping="Wrap"
                       FontSize="13" />
          </Grid>
        </Border>

        <!-- Botón Generar -->
        <Button Classes="primary"
                Content="Generar secuencia"
                Command="{Binding GenerarCommand}"
                Margin="0,16,0,0"
                HorizontalAlignment="Left" />

      </StackPanel>
    </ScrollViewer>

    <!-- ── DataGrid de resultados ──────────────────────────────────────── -->
    <DataGrid Grid.Row="1"
              ItemsSource="{Binding Resultados}"
              IsReadOnly="True"
              AutoGenerateColumns="False"
              CanUserReorderColumns="False"
              CanUserResizeColumns="True"
              CanUserSortColumns="False"
              GridLinesVisibility="Horizontal"
              Background="#0E0E1E"
              BorderThickness="0,1,0,0"
              BorderBrush="#2A2A4A"
              RowBackground="#0E0E1E"
              Margin="0">

      <DataGrid.Columns>
        <DataGridTextColumn Header="n (Iteración)"
                            Binding="{Binding N}"
                            Width="120" />
        <DataGridTextColumn Header="Xₙ (Estado)"
                            Binding="{Binding Xn}"
                            Width="*" />
        <DataGridTextColumn Header="Uₙ (Número aleatorio)"
                            Binding="{Binding Un, StringFormat={}{0:F10}}"
                            Width="2*" />
      </DataGrid.Columns>
    </DataGrid>

    <!-- ── Aviso de ciclo / degeneración ─────────────────────────────────── -->
    <Border Grid.Row="2"
            Classes="cycle-panel"
            IsVisible="{Binding TieneCiclo}"
            Margin="32,10,32,0">
      <Grid ColumnDefinitions="22,8,*">
        <TextBlock Grid.Column="0" Text="🔄" FontSize="14" VerticalAlignment="Top" />
        <TextBlock Grid.Column="2"
                   Text="{Binding MensajeCiclo}"
                   Foreground="#AFD8FF"
                   TextWrapping="Wrap"
                   FontSize="13" />
      </Grid>
    </Border>

    <!-- ── Barra de exportación ────────────────────────────────────────── -->
    <Border Grid.Row="3"
            Background="#1A1A2E"
            BorderBrush="#2A2A4A"
            BorderThickness="0,1,0,0"
            Padding="32,10">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   VerticalAlignment="Center"
                   Foreground="#5A5A8A"
                   FontSize="12"
                   Text="{Binding Resultados.Count, StringFormat='Total: {0} valores generados'}" />
        <Button DockPanel.Dock="Right"
                Classes="secondary"
                Content="⬇  Exportar U_n a .txt"
                Command="{Binding ExportarCommand}"
                IsEnabled="{Binding PuedeExportar}" />
      </DockPanel>
    </Border>

  </Grid>
</UserControl>
