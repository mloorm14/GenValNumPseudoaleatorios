<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GenValNumAl.ViewModels"
             x:Class="GenValNumAl.Views.LaggedFibonacciView"
             x:DataType="vm:FibonacciRetardadoViewModel">

  <Grid RowDefinitions="Auto,*,Auto,Auto">

    <!-- ── Encabezado + formulario ─────────────────────────────────────── -->
    <ScrollViewer Grid.Row="0"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  MaxHeight="400">
      <StackPanel Margin="32,28,32,16" Spacing="0">

        <TextBlock Classes="section-title" Text="Fibonacci Retardado" />
        <TextBlock Classes="formula"
                   Text="Xₙ = (Xₙ₋ⱼ + Xₙ₋ₖ) mod m    Uₙ = Xₙ / m" />
        <TextBlock FontSize="11"
                   Foreground="#5A5A9A"
                   Margin="0,-8,0,16"
                   TextWrapping="Wrap"
                   Text="La tabla muestra primero las k semillas y luego los n valores adicionales generados." />

        <!-- Fila 1: j, k, m -->
        <Grid ColumnDefinitions="*,16,*,16,*">
          <StackPanel Grid.Column="0">
            <TextBlock Classes="input-label" Text="Rezago j (0 &lt; j &lt; k)" />
            <TextBox Classes="input-field" Text="{Binding J}" Watermark="ej: 2" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Classes="input-label" Text="Rezago k (k &gt; j)" />
            <TextBox Classes="input-field" Text="{Binding K}" Watermark="ej: 5" />
          </StackPanel>
          <StackPanel Grid.Column="4">
            <TextBlock Classes="input-label" Text="Módulo (m)" />
            <TextBox Classes="input-field" Text="{Binding M}" Watermark="ej: 10" />
          </StackPanel>
        </Grid>

        <!-- Fila 2: semillas, n -->
        <Grid ColumnDefinitions="2*,16,*" Margin="0,10,0,0">
          <StackPanel Grid.Column="0">
            <TextBlock Classes="input-label" Text="Semillas X₁…Xₖ (exactamente k valores separados por coma)" />
            <TextBox Classes="input-field"
                     Text="{Binding Semillas}"
                     Watermark="ej: 1, 6, 3, 2, 9" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Classes="input-label" Text="Valores adicionales (n)" />
            <TextBox Classes="input-field" Text="{Binding N}" Watermark="ej: 10" />
          </StackPanel>
        </Grid>

        <!-- Error -->
        <Border Classes="error-panel" IsVisible="{Binding TieneError}">
          <Grid ColumnDefinitions="22,8,*">
            <TextBlock Grid.Column="0" Text="⚠" Foreground="#FF6B6B" FontSize="16" VerticalAlignment="Top" />
            <TextBlock Grid.Column="2"
                       Text="{Binding MensajeError}"
                       Foreground="#FF9999"
                       TextWrapping="Wrap"
                       FontSize="13" />
          </Grid>
        </Border>

        <Button Classes="primary"
                Content="Generar secuencia"
                Command="{Binding GenerarCommand}"
                Margin="0,16,0,0"
                HorizontalAlignment="Left" />

      </StackPanel>
    </ScrollViewer>

    <!-- ── DataGrid ──────────────────────────────────────────────────────── -->
    <DataGrid Grid.Row="1"
              ItemsSource="{Binding Resultados}"
              IsReadOnly="True"
              AutoGenerateColumns="False"
              CanUserReorderColumns="False"
              CanUserResizeColumns="True"
              CanUserSortColumns="False"
              GridLinesVisibility="Horizontal"
              Background="#0E0E1E"
              BorderThickness="0,1,0,0"
              BorderBrush="#2A2A4A"
              RowBackground="#0E0E1E">
      <DataGrid.Columns>
        <DataGridTextColumn Header="n (Posición)"           Binding="{Binding N}"                            Width="120" />
        <DataGridTextColumn Header="Xₙ (Estado)"            Binding="{Binding Xn}"                           Width="*" />
        <DataGridTextColumn Header="Uₙ (Número aleatorio)"  Binding="{Binding Un, StringFormat={}{0:F10}}"   Width="2*" />
      </DataGrid.Columns>
    </DataGrid>

    <!-- ── Aviso de ciclo / degeneración ─────────────────────────────────── -->
    <Border Grid.Row="2"
            Classes="cycle-panel"
            IsVisible="{Binding TieneCiclo}"
            Margin="32,10,32,0">
      <Grid ColumnDefinitions="22,8,*">
        <TextBlock Grid.Column="0" Text="🔄" FontSize="14" VerticalAlignment="Top" />
        <TextBlock Grid.Column="2"
                   Text="{Binding MensajeCiclo}"
                   Foreground="#AFD8FF"
                   TextWrapping="Wrap"
                   FontSize="13" />
      </Grid>
    </Border>

    <!-- ── Barra de exportación ──────────────────────────────────────────── -->
    <Border Grid.Row="3"
            Background="#1A1A2E"
            BorderBrush="#2A2A4A"
            BorderThickness="0,1,0,0"
            Padding="32,10">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   VerticalAlignment="Center"
                   Foreground="#5A5A8A"
                   FontSize="12"
                   Text="{Binding Resultados.Count, StringFormat='Total: {0} filas (semillas + generados)'}" />
        <Button DockPanel.Dock="Right"
                Classes="secondary"
                Content="⬇  Exportar U_n a .txt"
                Command="{Binding ExportarCommand}"
                IsEnabled="{Binding PuedeExportar}" />
      </DockPanel>
    </Border>

  </Grid>
</UserControl>
